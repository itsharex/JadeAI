# ===== App =====
APP_NAME=JadeAI

# ===== Auth =====
AUTH_ENABLED=false
AUTH_SECRET=your-auth-secret-key-change-me

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== Database =====
DB_TYPE=sqlite

# PostgreSQL (when DB_TYPE=postgresql)
DATABASE_URL=postgresql://user:password@localhost:5432/jadeai

# SQLite (when DB_TYPE=sqlite)
SQLITE_PATH=./data/jade.db

# ===== i18n =====
DEFAULT_LOCALE=zh
